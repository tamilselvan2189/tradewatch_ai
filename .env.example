APP_ENV=dev
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=mysql+pymysql://root:root@localhost:3306/tradewatch?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_me_with_generated_key

GROWW_BASE_URL=https://api.groww.in
GROWW_API_KEY=replace_me
GROWW_API_SECRET=replace_me
GROWW_TIMEOUT_SECONDS=20
GROWW_SESSION_TTL_MINUTES=60

SCHEDULER_TIMEZONE=Asia/Kolkata
